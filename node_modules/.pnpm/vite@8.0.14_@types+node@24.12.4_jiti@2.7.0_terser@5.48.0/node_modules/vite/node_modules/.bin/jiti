            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/alexeyshevin/construction-journal/node_modules/.pnpm/jiti@2.7.0/node_modules/jiti/node_modules:/home/alexeyshevin/construction-journal/node_modules/.pnpm/jiti@2.7.0/node_modules:/home/alexeyshevin/construction-journal/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/alexeyshevin/construction-journal/node_modules/.pnpm/jiti@2.7.0/node_modules/jiti/node_modules:/home/alexeyshevin/construction-journal/node_modules/.pnpm/jiti@2.7.0/node_modules:/home/alexeyshevin/construction-journal/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../jiti/lib/jiti-cli.mjs" "$@"
else
  exec node  "$basedir/../../../jiti/lib/jiti-cli.mjs" "$@"
fi
