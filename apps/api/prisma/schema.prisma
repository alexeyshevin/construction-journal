generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WorkType {
  id       String    @id @default(uuid())
  name     String    @unique
  unit     String
  workLogs WorkLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkLog {
  id            String   @id @default(uuid())
  workDate      DateTime
  amount        Float
  unit          String
  performerName String

  workTypeId String
  workType   WorkType @relation(fields: [workTypeId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workDate])
  @@index([workTypeId])
}